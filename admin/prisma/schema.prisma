generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  rss
  telegram
}

model Source {
  id        String     @id @default(cuid())
  label     String
  type      SourceType
  rssUrl    String?
  channel   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([type])
}
